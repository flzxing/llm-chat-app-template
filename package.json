{
	"name": "llm-chat-app-template",
	"description": "A simple chat application powered by Cloudflare Workers AI",
	"cloudflare": {
		"label": "LLM Chat App",
		"products": [
			"Workers",
			"Workers AI",
			"AI Gateway"
		],
		"categories": [
			"ai"
		],
		"docs_url": "https://developers.cloudflare.com/workers-ai/",
		"preview_icon_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/a974bd55-20c6-4656-fa29-1551d43ddc00/public",
		"preview_image_url": "https://imagedelivery.net/wSMYJvS3Xw-n339CbDyDIA/65dd8441-89d3-491d-c5a1-0a000d070700/preview",
		"publish": true
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.10.11",
		"@cloudflare/workers-types": "^4.20250425.0",
		"@opentelemetry/api": "^1.9.1",
		"@types/node": "24.10.1",
		"better-sqlite3": "^12.8.0",
		"patch-package": "^8.0.1",
		"typescript": "5.9.3",
		"vitest": "3.2.4",
		"wrangler": "4.56.0"
	},
	"private": true,
	"scripts": {
		"postinstall": "patch-package",
		"cf-typegen": "wrangler types",
		"check": "tsc --noEmit && wrangler deploy --dry-run",
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"db:local:migrate": "wrangler d1 migrations apply kmp-ai-db --local",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:manual": "node scripts/manual-api-check.mjs",
		"test:local:all": "npm run test && npm run test:manual"
	},
	"dependencies": {
		"better-auth": "^1.6.2",
		"hono": "^4.12.12"
	}
}
