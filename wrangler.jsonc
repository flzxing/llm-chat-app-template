/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "llm-chat-app-template",
	"main": "src/index.ts",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./public"
	},
	// 生产部署用；本地 wrangler dev 以 .dev.vars 中的 BETTER_AUTH_URL 覆盖
	"vars": {
		"BETTER_AUTH_URL": "https://llm-chat-app-template.zhouxing87808911.workers.dev",
		// OpenAI 兼容 Workers AI：`https://api.cloudflare.com/client/v4/accounts/{id}/ai/v1/chat/completions`
		"CLOUDFLARE_ACCOUNT_ID": "04261ff01cec2227fc3194c65e84a18a",
		// OTP 邮件发件地址（Resend verified domain）；RESEND_API_KEY 请用 secret 注入
		"RESEND_FROM_EMAIL": "no-reply@luckyaitool.com",
		// 可选：发件人展示名
		"RESEND_FROM_NAME": "LLM Chat App",
		"TOOL_EMBED_MODEL": "@cf/baai/bge-base-en-v1.5",
		"TOOL_RETRIEVAL_TOP_N": "2",
		"TOOL_RETRIEVAL_TOP_K": "20",
		"TOOL_RETRIEVAL_SCORE_THRESHOLD": "0.45",
		"TOOL_VECTORIZE_AUTO_SYNC": "false"
	},
	"ai": {
		"binding": "AI"
	},
	"vectorize": [
		{
			"binding": "TOOL_INDEX",
			"index_name": "llm-chat-tools-index"
		},
		{
			"binding": "VECTORIZE",
			"index_name": "llm-chat-tools-index",
			"remote": true
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "kmp-ai-db",
			"database_id": "ef3619ac-5659-4447-b36d-119051dd38af"
		}
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true
}